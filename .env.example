# ─── Next.js (racine du repo) — copier vers .env et remplir les valeurs ───
#
# Neon / Postgres (même URL possible pour l’app et l’agent Python, voir README)
DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth — URL publique de l’app (dev)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth — secret de signature des JWT / cookies (OBLIGATOIRE en prod)
# Générer une valeur :  openssl rand -base64 32
NEXTAUTH_SECRET=""

# API FastAPI agent — base seulement, sans /api/v1 (défaut local ci‑dessous)
AGENT_API_BASE_URL="http://127.0.0.1:8000"
# Alias accepté par le code (même effet) :
# AGENT_API_URL="http://127.0.0.1:8000"

# Délai entre chaque morceau de texte simulé (ms) pour un rendu type « streaming ».
# 0 = envoi en rafale (un seul tick). Défaut 12.
# AGENT_CHAT_STREAM_CHUNK_DELAY_MS=12
